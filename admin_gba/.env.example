# Public (browser) — Supabase : Project Settings → API
# Authentication → URL Configuration → Redirect URLs, ajouter :
#   https://VOTRE_DOMAINE_VERCEL/reset-password
#   com.gba.ecommerce_client://login-callback
#   com.gba.ecommerce_client.driver://login-callback   (flavor livreur)
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Email (Resend) — https://resend.com — plan gratuit sans domaine :
# - Créer une clé API ; expéditeur par défaut côté app : GBA <onboarding@resend.dev>
# - Sans domaine vérifié : n’envoyer qu’à l’email de votre compte Resend (ou adresses de test Resend).
RESEND_API_KEY=
# Optionnel : si vide, l’app utilise onboarding@resend.dev + nom « GBA »
EMAIL_FROM=onboarding@resend.dev
EMAIL_FROM_NAME=GBA
ADMIN_NOTIFICATION_EMAIL=votre-email@exemple.com
EMAIL_PROVIDER=auto

# SMTP (Option B - Brevo recommandé)
# Alias supportés par mailer.ts : BREVO_SMTP_HOST / BREVO_SMTP_USER / BREVO_SMTP_PASS
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
BREVO_SMTP_HOST=
BREVO_SMTP_USER=
BREVO_SMTP_PASS=
SMTP_POOL=true
SMTP_MAX_CONNECTIONS=3
SMTP_MAX_MESSAGES=50
SMTP_TIMEOUT_MS=15000
ADMIN_CC_EMAILS=
CRON_SECRET=
NEXT_PUBLIC_ADMIN_URL=http://localhost:3000

# GeoIP (carte + sessions) : ipwho | ipinfo | off
GEOIP_PROVIDER=ipwho
# Si GEOIP_PROVIDER=ipinfo — https://ipinfo.io
IPINFO_TOKEN=
# Timeout ms par requête GeoIP (défaut 1500)
GEOIP_TIMEOUT_MS=1500