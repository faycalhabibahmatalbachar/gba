# GBA — Variables d'environnement (copier ce fichier en .env et remplir les valeurs)
# Ne jamais committer le fichier .env !

# ── Supabase ───────────────────────────────────────────────────────────────────
SUPABASE_URL=https://uvlrgwdbjegoavjfdrzb.supabase.co
# Clé service_role : Supabase Dashboard → Project Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=

# ── Unsplash (source principale pour images produits) ─────────────────────────
# Créer un compte sur https://unsplash.com/developers → New Application → Access Key
UNSPLASH_ACCESS_KEY=

# ── Pexels (fallback si Unsplash ne retourne rien) ────────────────────────────
# Créer un compte sur https://www.pexels.com/api/ → Your API Key
PEXELS_API_KEY=